# Copy to .env (git-ignored) and fill in. Used by `make live`.

# IAM User credentials.
VNGCLOUD_ROOT_EMAIL=
VNGCLOUD_USERNAME=
VNGCLOUD_PASSWORD=

# Base32 TOTP secret if the IAM user enforces 2FA (the SDK computes codes
# itself; no manual OTP entry needed).
VNGCLOUD_TOTP_SECRET=

# Optional: comma-separated regions to test, defaults to hcm-3,han-1.
VNGCLOUD_REGIONS=hcm-3,han-1

# Optional: skip project discovery (single-region use only).
VNGCLOUD_PROJECT_ID=

# Optional: bearer token from an authenticated console session.
# When set, the live test skips IAM login entirely (captcha workaround).
VNGCLOUD_ACCESS_TOKEN=
